# PPT复刻Skill - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不应提交到版本控制！

# ============================================
# 飞书应用凭证（必填）
# ============================================
# 飞书开放平台: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# 飞书事件订阅配置（Webhook模式可选）
# ============================================
# 事件订阅加密密钥（用于验证飞书推送的事件）
FEISHU_ENCRYPT_KEY=

# 验证Token（URL验证时使用）
FEISHU_VERIFICATION_TOKEN=

# ============================================
# 分享链接配置（可选）
# ============================================
# 分享链接范围: anyone（任何人）或 tenant（仅企业内）
FEISHU_SHARE_SCOPE=anyone

# ============================================
# 应用配置（可选）
# ============================================
# 文件下载目录
DOWNLOAD_DIR=./downloads

# 文件输出目录
OUTPUT_DIR=./output

# 默认生成PPT页面数
DEFAULT_SLIDE_COUNT=10

# ============================================
# 日志配置（可选）
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
